option(xsUSE_3RDPARTY "Enable configure 3rdparty" OFF)
option(xsUSE_3RDPARTY_WXWIDGETS "Enable configure 3rdparty - wxWidgets" ON)
option(xsUSE_3RDPARTY_LIBUV "Enable configure 3rdparty - libuv" ON)
option(xsUSE_3RDPARTY_TINYXML2 "Enable configure 3rdparty - tinyxml2" ON)
option(xsUSE_3RDPARTY_ZLIB "Enable configure 3rdparty - zlib" ON)
option(xsUSE_3RDPARTY_MINIZIP "Enable configure 3rdparty - minizip" ON)
option(xsUSE_3RDPARTY_SQLITE3 "Enable configure 3rdparty - sqlite3" ON)
option(xsUSE_3RDPARTY_CURL "Enable configure 3rdparty - curl" ON)
option(xsUSE_3RDPARTY_HTTP_PARSER "Enable configure 3rdparty - http-parser" ON)
option(xsUSE_3RDPARTY_UTF8CPP "Enable configure 3rdparty - utf8cpp" ON)

if(xsUSE_3RDPARTY)
  set(CMAKE_DEBUG_POSTFIX
      ""
      CACHE STRING "..." FORCE)
  set(CMAKE_INSTALL_PREFIX
      ${xsBUILD_INSTALLED_DIR}/${CMAKE_BUILD_TYPE}
      CACHE STRING "Install path prefix, prepended onto install directories."
            FORCE)
endif()

if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_WXWIDGETS)
  include(build/cmake/deps/wxWidgets.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_UTF8CPP)
  include(build/cmake/deps/utf8cpp.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_HTTP_PARSER)
  include(build/cmake/deps/http_parser.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_CURL)
  include(build/cmake/deps/CURL.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_LIBUV)
  include(build/cmake/deps/libuv.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_TINYXML2)
  include(build/cmake/deps/tinyxml2.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_ZLIB)
  include(build/cmake/deps/zlib.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_MINIZIP)
  include(build/cmake/deps/minizip.cmake)
endif()
if(xsUSE_3RDPARTY AND xsUSE_3RDPARTY_SQLITE3)
  include(build/cmake/deps/sqlite3.cmake)
endif()
