      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/tests/test_main/test_main",
      "args": [
        // "--get-processes"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
