{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug On CMake",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build_win"
            ],
            "dependsOn":"cmake-configure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        },
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-G", "Ninja",
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build_win",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "problemMatcher": []
        }
    ]
}
