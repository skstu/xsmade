prefix=
exec_prefix=
libdir=${pcfiledir}/../../../libavfilter
includedir=.

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 10.6.101
Requires:  libswscale >= 8.9.101,  libpostproc >= 58.4.100,  libavformat >= 61.9.100,  libavcodec >= 61.24.100,  libswresample >= 5.4.100,  libavutil >= 59.47.100
Conflicts:
Libs: -L${libdir} -Wl,-rpath,${libdir} -lavfilter -lm
Cflags: -I${includedir}
