prefix=
exec_prefix=
libdir=${pcfiledir}/../../../libavformat
includedir=.

Name: libavformat
Description: FFmpeg container format library
Version: 61.9.100
Requires:  libavcodec >= 61.24.100,  libswresample >= 5.4.100,  libavutil >= 59.47.100
Conflicts:
Libs: -L${libdir} -Wl,-rpath,${libdir} -lavformat -lm -lbz2 -lz -lsecur32 -lws2_32
Cflags: -I${includedir}
